  "main": "src/dsl/api.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts demos/**/*.ts"
  },
  "keywords": [
    "animation",
    "dsl",
    "typescript",
    "mathematics",
